{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://delegent.example/schemas/authority-grant-claims.schema.json",
  "title": "Delegent Authority Grant Claims",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "grant_id",
    "grant_profile",
    "issuer",
    "issued_at",
    "expires_at",
    "audience",
    "workload_id",
    "workload_issuer",
    "delegation_id",
    "delegation_source_type",
    "delegation_purpose",
    "project_id",
    "session_id",
    "allowed_actions",
    "sender_constraint_id",
    "replay_handle",
    "revocation_status_ref"
  ],
  "properties": {
    "grant_id": { "type": "string", "minLength": 1 },
    "grant_profile": { "const": "delegent-authority-grant.v0" },
    "issuer": { "type": "string", "minLength": 1 },
    "issued_at": { "type": "string", "format": "date-time" },
    "not_before": { "type": ["string", "null"], "format": "date-time" },
    "expires_at": { "type": "string", "format": "date-time" },
    "audience": { "type": "string", "minLength": 1 },
    "workload_id": { "type": "string", "minLength": 1 },
    "workload_issuer": { "type": "string", "minLength": 1 },
    "delegation_id": { "type": "string", "minLength": 1 },
    "delegation_source_type": { "type": "string", "minLength": 1 },
    "delegation_purpose": { "type": "string", "minLength": 1 },
    "project_id": { "type": "string", "minLength": 1 },
    "session_id": { "type": "string", "minLength": 1 },
    "allowed_actions": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 1 },
      "uniqueItems": true
    },
    "sender_constraint_id": { "type": "string", "minLength": 1 },
    "replay_handle": { "type": "string", "minLength": 1 },
    "revocation_status_ref": { "type": "string", "minLength": 1 },
    "policy_decision_id": { "type": ["string", "null"], "minLength": 1 },
    "attestation_result_id": { "type": ["string", "null"], "minLength": 1 },
    "sensitivity": { "type": ["string", "null"], "minLength": 1 },
    "request_context_hash": { "type": ["string", "null"], "minLength": 1 }
  }
}
